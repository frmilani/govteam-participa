# =============================================================================
# SPOKE: PRÊMIO DESTAQUE - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Este arquivo contém todas as variáveis de ambiente necessárias para o Spoke.
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no Git!
# =============================================================================

# -----------------------------------------------------------------------------
# 1. BANCO DE DADOS (PostgreSQL)
# -----------------------------------------------------------------------------
# URL de conexão com o banco PostgreSQL do Spoke
# Formato: postgresql://[usuário]:[senha]@[host]:[porta]/[database]
# 
# ⚠️ IMPORTANTE: 
# - Cada Spoke deve ter seu próprio banco de dados separado
# - O banco deve existir antes de rodar as migrations
# - Use um usuário com permissões de CREATE/ALTER/DROP
# - Em produção, adicione ?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/premio_destaque"

# -----------------------------------------------------------------------------
# 2. AUTENTICAÇÃO (NextAuth.js)
# -----------------------------------------------------------------------------
# URL pública do Spoke (onde os usuários acessam)
# Em desenvolvimento: http://localhost:3001 (ou porta configurada)
# Em produção: https://premio.seudominio.com.br
NEXTAUTH_URL="http://localhost:3001"

# Chave secreta usada pelo NextAuth.js para criptografar tokens e cookies
# Esta chave é CRÍTICA para a segurança do sistema!
#
# ⚠️ COMO GERAR:
# Execute no terminal: openssl rand -base64 32
# Ou use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ⚠️ CRÍTICO - LEIA COM ATENÇÃO:
# - Esta chave DEVE SER DIFERENTE da AUTH_SECRET do Hub!
# - Se for igual ao Hub, o OAuth não funcionará (erro: InvalidCheck)
# - Cada Spoke deve ter sua própria chave única
# - Nunca compartilhe esta chave entre ambientes ou sistemas
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Alternativa ao NEXTAUTH_SECRET (NextAuth.js v5+)
# Use a mesma chave gerada acima
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Confiar no host do proxy reverso (necessário em produção com Nginx/Apache)
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# 3. INTEGRAÇÃO COM O HUB (OAuth2 SSO)
# -----------------------------------------------------------------------------
# URL pública do Hub (acessível pelo navegador do usuário)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://hub.seudominio.com.br
HUB_URL="http://localhost:3000"

# URL interna do Hub (para comunicação server-to-server)
# Em desenvolvimento local: mesmo que HUB_URL
# Em Docker/Kubernetes: use o nome do serviço (ex: http://hub:3000)
# Em produção com rede interna: use IP/hostname interno
HUB_INTERNAL_URL="http://localhost:3000"

# Client ID do Spoke registrado no Hub
# Este valor é o SLUG do Spoke no catálogo do Hub
# Para este Spoke: "premio-destaque"
# ⚠️ Deve corresponder ao campo "slug" na tabela Spoke do Hub
HUB_CLIENT_ID="premio-destaque"

# Client Secret do Spoke (configurado no Hub)
# Este valor é gerado/configurado no painel /sys/spokes do Hub
# ⚠️ Deve corresponder ao campo "clientSecret" na tabela Spoke do Hub
# ⚠️ Mantenha este valor em segredo absoluto!
HUB_CLIENT_SECRET="secret-from-hub-admin"

# NOTA: HUB_API_KEY foi removido. A autenticação server-to-server
# agora usa HUB_CLIENT_ID + HUB_CLIENT_SECRET (spoke auth multi-tenant).

# -----------------------------------------------------------------------------
# 4. CONFIGURAÇÕES PÚBLICAS DO SPOKE
# -----------------------------------------------------------------------------
# Estas variáveis são expostas no frontend (prefixo NEXT_PUBLIC_)

# URL pública do Spoke (usada no frontend para links e redirects)
NEXT_PUBLIC_SPOKE_URL="http://localhost:3001"

# URL pública do Hub (usada no frontend para links de logout, perfil, etc.)
NEXT_PUBLIC_HUB_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# 5. ARMAZENAMENTO DE ARQUIVOS (S3/MinIO)
# -----------------------------------------------------------------------------
# Configuração para upload de fotos de candidatos, documentos, etc.

# URL do endpoint S3/MinIO
S3_ENDPOINT="http://localhost:9000"

# Credenciais de acesso
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"

# Nome do bucket (deve existir no S3/MinIO)
S3_BUCKET="premio-destaque"

# Região (obrigatório mesmo para MinIO)
S3_REGION="us-east-1"

# URL pública para acessar arquivos (opcional)
# S3_PUBLIC_URL="http://localhost:9000/premio-destaque"

# -----------------------------------------------------------------------------
# 6. CACHE E FILAS (Redis)
# -----------------------------------------------------------------------------
# URL de conexão com o Redis (usado para cache e filas de jobs)
# Em desenvolvimento: redis://localhost:6379
# Em produção: redis://:senha@host:6379/0
# Com TLS: rediss://host:6379
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# 7. INTEGRAÇÃO WHATSAPP (Evolution API) - OPCIONAL
# -----------------------------------------------------------------------------
# Usado para enviar notificações de votação, resultados, etc.

# URL da Evolution API
EVOLUTION_API_URL="http://localhost:8080"

# API Key da Evolution API
EVOLUTION_API_KEY="your-evolution-api-key"

# -----------------------------------------------------------------------------
# 8. CONFIGURAÇÕES OPCIONAIS
# -----------------------------------------------------------------------------

# Modo de desenvolvimento (habilita logs extras e hot reload)
# NODE_ENV="development"

# Porta do servidor (padrão: 3000, mas recomendado 3001+ para Spokes)
# PORT=3001

# Nível de log (error, warn, info, debug)
# LOG_LEVEL="info"
