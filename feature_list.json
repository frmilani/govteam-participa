    {
      "id": "RF-001",
      "title": "Autenticação e SSO via OAuth2",
      "description": "Implementar autenticação via OAuth2 com FormBuilder Hub",
      "tests": [
        {
          "category": "functional",
          "description": "Login via Hub redireciona corretamente",
          "steps": ["Acessar /admin sem estar logado", "Verificar redirecionamento para Hub OAuth", "Fazer login no Hub", "Verificar redirecionamento de volta para /admin"],
          "passes": "pending_manual_test"
        },
        {
          "category": "functional",
          "description": "Token contém organizationId",
          "steps": ["Fazer login via Hub", "Inspecionar token JWT", "Verificar presença de organizationId", "Verificar presença de role"],
          "passes": "pending_manual_test"
        },
        {
          "category": "security",
          "description": "Middleware protege rotas admin",
          "steps": ["Tentar acessar /admin/enquetes sem token", "Verificar redirecionamento para login", "Fazer login", "Verificar acesso permitido"],
          "passes": "pending_manual_test"
        },
        {
          "category": "functional",
          "description": "Rotas públicas acessíveis sem login",
          "steps": ["Acessar /r/[hash] sem login", "Verificar acesso permitido", "Acessar /vote/[hash]", "Verificar renderização da landing page"],
          "passes": "pending_manual_test"
        }
      ]
    },
